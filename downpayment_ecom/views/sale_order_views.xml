<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Show downpayment info on sale order form -->
    <record id="sale_order_view_form_inherit_downpayment" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.downpayment</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="use_downpayment" readonly="1"
                       invisible="not use_downpayment"/>
                <field name="downpayment_amount"
                       invisible="not use_downpayment"/>
            </xpath>
        </field>
    </record>

</odoo>
