<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_inherit_downpayment" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.downpayment</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='website_sale_price']/.." position="after">
                <block title="Downpayment" name="downpayment_setting">
                    <setting id="downpayment_setting" string="Downpayment"
                             help="Allow customers to pay a partial amount at checkout">
                        <field name="downpayment_enabled"/>
                        <div invisible="not downpayment_enabled" class="mt-3">
                            <div class="row mt-2">
                                <label for="downpayment_type" string="Type" class="col-lg-3"/>
                                <field name="downpayment_type" class="col-lg-3"/>
                            </div>
                            <div class="row mt-2">
                                <label for="downpayment_value" string="Value" class="col-lg-3"/>
                                <field name="downpayment_value" class="col-lg-2"/>
                                <span invisible="downpayment_type != 'percentage'">%</span>
                            </div>
                            <div class="row mt-2">
                                <label for="downpayment_minimum_amount" string="Minimum Order Amount" class="col-lg-3"/>
                                <field name="downpayment_minimum_amount" class="col-lg-3"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>
